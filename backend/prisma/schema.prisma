generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  SUPER_ADMIN
  AGENCY_ADMIN
  AGENCY_EMPLOYEE
}

enum ApplicationStatus {
  DRAFT
  REVIEW
  READY
  SUBMITTED
  PROCESSING
  APPROVED
  REJECTED
  DELIVERED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

// ==================== CORE ENTITIES ====================

model Organization {
  id                String    @id @default(cuid())
  name              String
  code              String    @unique
  email             String    @unique
  phone             String?
  address           String?
  logo              String?
  maxSeats          Int       @default(10)
  usedSeats         Int       @default(0)
  isActive          Boolean   @default(true)
  subscriptionEnd   DateTime?
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  users             User[]
  groups            Group[]
  applicants        Applicant[]
  applications      Application[]
  templates         Template[]
  imports           Import[]
  applicantDrafts   ApplicantDraft[]
  auditLogs         AuditLog[]
  visaForms         VisaApplicationForm[]
  batchTemplates    BatchPreFillTemplate[]
  visaApplications  CompleteVisaApplication[]
  visaDocuments     VisaApplicationDocument[]

  @@index([code])
  @@index([email])
  @@map("organizations")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  role              UserRole
  phone             String?
  avatar            String?
  isActive          Boolean   @default(true)
  lastLogin         DateTime? @db.Timestamp(3)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  sessions          Session[]
  blacklistedTokens TokenBlacklist[]
  assignedGroups    Group[]       @relation("GroupEmployee")
  auditLogs         AuditLog[]
  appliedBatches    BatchPreFillTemplate[] @relation("AppliedByEmployee")
  reviewedApplications CompleteVisaApplication[] @relation("ReviewedBy")
  uploadedDocuments VisaApplicationDocument[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model Session {
  id                String    @id @default(cuid())
  token             String    @unique
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt         DateTime  @db.Timestamp(3)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

// ==================== VISA PROCESSING ====================

model Group {
  id                String    @id @default(cuid())
  code              String
  name              String
  travelDate        DateTime? @db.Timestamp(3)
  externalAgent     String?
  notes             String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedEmployeeId String?
  assignedEmployee  User?     @relation("GroupEmployee", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  applicants        Applicant[]
  imports           Import[]
  visaForms         VisaApplicationForm[]
  batchTemplates    BatchPreFillTemplate[]
  visaApplications  CompleteVisaApplication[]

  @@unique([code, organizationId])
  @@index([organizationId])
  @@index([assignedEmployeeId])
  @@index([isActive])
  @@map("groups")
}

model Applicant {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  email             String?
  phone             String?
  dob               DateTime? @db.Timestamp(3)
  gender            String?
  nationality       String?
  passportNumber    String?
  passportExpiry    DateTime? @db.Timestamp(3)
  passportIssue     DateTime? @db.Timestamp(3)
  address           String?
  city              String?
  country           String?
  photo             String?
  documents         Json?
  notes             String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  groupId           String
  group             Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  applications      Application[]
  visaForms         VisaApplicationForm[]
  visaApplications  CompleteVisaApplication[]

  @@index([organizationId])
  @@index([groupId])
  @@index([email])
  @@index([passportNumber])
  @@map("applicants")
}

model Application {
  id                String    @id @default(cuid())
  referenceNumber   String    @unique
  visaType          String
  destinationCountry String
  status            ApplicationStatus @default(DRAFT)
  submittedAt       DateTime? @db.Timestamp(3)
  processedAt       DateTime? @db.Timestamp(3)
  approvedAt        DateTime? @db.Timestamp(3)
  rejectedAt        DateTime? @db.Timestamp(3)
  rejectionReason   String?
  notes             String?
  documents         Json?
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  applicantId       String
  applicant         Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  templateId        String?
  template          Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  auditLogs         AuditLog[]

  @@index([organizationId])
  @@index([applicantId])
  @@index([templateId])
  @@index([status])
  @@index([referenceNumber])
  @@map("applications")
}

model Template {
  id                String    @id @default(cuid())
  name              String
  country           String
  visaType          String
  description       String?
  fields            Json
  conditions        Json?
  version           Int       @default(1)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  applications      Application[]

  @@unique([name, country, visaType, organizationId])
  @@index([organizationId])
  @@index([country])
  @@index([visaType])
  @@map("templates")
}

// ==================== IMPORTS & OCR ====================

model Import {
  id                String    @id @default(cuid())
  fileName          String
  fileType          String
  fileSize          Int
  filePath          String
  status            ImportStatus @default(PENDING)
  processedCount    Int       @default(0)
  totalCount        Int       @default(0)
  errorCount        Int       @default(0)
  errors            Json?
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  groupId           String?
  group             Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)

  drafts            ApplicantDraft[]

  @@index([organizationId])
  @@index([groupId])
  @@index([status])
  @@map("imports")
}

model ApplicantDraft {
  id                String    @id @default(cuid())
  importId          String
  import            Import    @relation(fields: [importId], references: [id], onDelete: Cascade)
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  extractedData     Json
  fieldConfidence   Json
  confidence        Int
  status            String    @default("PENDING_REVIEW")
  corrections       Json?
  originalSource    String?
  reviewedBy        String?
  reviewedAt        DateTime? @db.Timestamp(3)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  @@index([importId])
  @@index([organizationId])
  @@index([status])
  @@index([confidence])
  @@map("applicant_drafts")
}

// ==================== AUDIT ====================

model AuditLog {
  id                String    @id @default(cuid())
  action            String
  entityType        String
  entityId          String
  oldValues         Json?
  newValues         Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime  @default(now()) @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId            String?
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  applicationId     String?
  application       Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([applicationId])
  @@index([entityType])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== VISA APPLICATION FORMS ====================

model VisaApplicationForm {
  id                String    @id @default(cuid())

  visaPhotoId       String?
  passportPage1Id   String?
  passportPage2Id   String?
  passportBackPageId String?

  fullName          String
  placeOfBirthCountry String?
  placeOfBirthProvince String?
  placeOfBirthCity  String?
  maritalStatus     String?
  maritalStatusOther String?

  hasOtherNationality Boolean @default(false)
  otherNationality  String?
  otherNationalityIdNumber String?
  otherNationalityPassportNumber String?
  otherNationalityNotProvidedReason String?

  hasPermanentResidence Boolean @default(false)
  permanentResidenceCountries String?

  hasFormerNationality Boolean @default(false)
  formerNationality String?

  currentOccupation String?
  workExperienceStartDate DateTime?
  workExperienceEndDate DateTime?
  companyName       String?
  companyAddress    String?
  companyPhone      String?
  supervisorName    String?
  supervisorPhone   String?
  position          String?
  duty              String?

  schoolName        String?
  educationLevel    String?
  majorSubject      String?

  residenceCountry  String?
  residenceProvince String?
  residenceCity     String?
  residenceStreet   String?
  residenceMobilePhone String?
  residencePhone    String?
  residenceEmail    String?

  spouseFirstName   String?
  spouseLastName    String?
  spouseDateOfBirth DateTime?
  spouseCountryOfBirth String?
  spouseCityOfBirth String?
  spouseAddress     String?
  spouseOccupation  String?

  fatherFirstName   String?
  fatherLastName    String?
  fatherNationality String?
  fatherDateOfBirth DateTime?
  fatherStillLiving Boolean?

  motherFirstName   String?
  motherLastName    String?
  motherNationality String?
  motherDateOfBirth DateTime?
  motherStillLiving Boolean?

  children          Json?

  emergencyFirstName String?
  emergencyLastName String?
  emergencyRelationship String?
  emergencyPhone    String?

  hasBeenToChina    Boolean @default(false)
  previousChineseVisaIds String?

  hasValidVisas     Boolean @default(false)
  validVisaCountries String?

  countriesVisitedLast12Months String?

  status            String    @default("DRAFT")
  applicantId       String?
  applicant         Applicant? @relation(fields: [applicantId], references: [id], onDelete: SetNull)

  // Relation to complete applications
  completeApplications CompleteVisaApplication[] @relation("FormData")

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  submittedAt       DateTime?

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  groupId           String
  group             Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([groupId])
  @@index([status])
  @@map("visa_application_forms")
}

// ==================== BATCH PRE-FILL TEMPLATES ====================

model BatchPreFillTemplate {
  id                String    @id @default(cuid())
  name              String
  description       String?

  inviterFullName   String?
  inviterCompanyName String?
  inviterPosition   String?
  inviterPhone      String?
  inviterEmail      String?
  inviterAddress    String?
  inviterCountry    String    @default("China")
  inviterProvince   String?
  inviterCity       String?

  purposeOfVisit    String?
  visaType          String?
  visaDuration      Int?
  intendedArrivalDate DateTime?
  intendedDepartureDate DateTime?

  hotelName         String?
  hotelAddress      String?
  hotelPhone        String?
  hotelCheckInDate  DateTime?
  hotelCheckOutDate DateTime?

  ticketReceiptIds  String?
  hotelBookingIds   String?
  itineraryIds      String?
  invitationLetterIds String?

  groupNumber       Int?
  groupLeaderName   String?
  groupLeaderPhone  String?

  insuranceProvider String?
  insurancePolicyNumber String?
  insuranceCoverageAmount String?

  visaFeeAmount     Decimal?
  serviceFeeAmount  Decimal?
  totalAmount       Decimal?
  paymentMethod     String?

  appliedByEmployeeId String?
  appliedByEmployee User?     @relation("AppliedByEmployee", fields: [appliedByEmployeeId], references: [id], onDelete: SetNull)

  isActive          Boolean   @default(true)

  // Relation to complete applications
  completeApplications CompleteVisaApplication[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  groupId           String
  group             Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([groupId])
  @@index([isActive])
  @@map("batch_pre_fill_templates")
}

// ==================== COMPLETE VISA APPLICATIONS ====================

model CompleteVisaApplication {
  id                String    @id @default(cuid())
  referenceNumber   String    @unique

  formDataId        String
  formData          VisaApplicationForm @relation("FormData", fields: [formDataId], references: [id], onDelete: Cascade)

  batchTemplateId   String?
  batchTemplate     BatchPreFillTemplate? @relation(fields: [batchTemplateId], references: [id], onDelete: SetNull)

  applicantFullName String
  applicantEmail    String?
  applicantPhone    String?
  applicantDOB      DateTime?

  inviterFullName   String?
  inviterCompany    String?
  inviterPhone      String?
  inviterEmail      String?

  purposeOfVisit    String?
  visaType          String?
  intendedArrivalDate DateTime?
  intendedDepartureDate DateTime?

  ticketReceiptIds  String?
  hotelBookingIds   String?
  itineraryIds      String?
  invitationLetterIds String?

  status            String    @default("DRAFT")

  submittedAt       DateTime?
  reviewedAt        DateTime?
  reviewedByUserId  String?
  reviewedByUser    User?     @relation("ReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  approvedAt        DateTime?
  rejectionReason   String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  groupId           String
  group             Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  applicantId       String?
  applicant         Applicant? @relation(fields: [applicantId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([groupId])
  @@index([applicantId])
  @@index([status])
  @@index([referenceNumber])
  @@map("complete_visa_applications")
}

// ==================== VISA APPLICATION DOCUMENTS ====================

model VisaApplicationDocument {
  id                String    @id @default(cuid())
  fileName          String
  fileType          String
  filePath          String
  fileSize          Int
  mimeType          String

  documentCategory  String
  documentType      String

  uploadedBy        String
  uploadedByUser    User      @relation(fields: [uploadedBy], references: [id])

  associatedWith    String?

  status            String    @default("PENDING")

  createdAt         DateTime  @default(now())

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([documentType])
  @@index([uploadedBy])
  @@map("visa_application_documents")
}

model TokenBlacklist {
  id                String    @id @default(cuid())
  token             String    @unique
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  blacklistedAt      DateTime  @default(now()) @db.Timestamp(3)
  expiresAt         DateTime  @db.Timestamp(3)
  reason            String?
  createdAt         DateTime  @default(now()) @db.Timestamp(3)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("token_blacklist")
}
