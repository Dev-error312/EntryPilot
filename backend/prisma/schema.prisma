generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  SUPER_ADMIN
  AGENCY_ADMIN
  AGENCY_EMPLOYEE
}

enum ApplicationStatus {
  DRAFT
  REVIEW
  READY
  SUBMITTED
  PROCESSING
  APPROVED
  REJECTED
  DELIVERED
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

// ==================== CORE ENTITIES ====================

model Organization {
  id                String    @id @default(cuid())
  name              String
  code              String    @unique
  email             String    @unique
  phone             String?
  address           String?
  logo              String?
  maxSeats          Int       @default(10)
  usedSeats         Int       @default(0)
  isActive          Boolean   @default(true)
  subscriptionEnd   DateTime?
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  users             User[]
  groups            Group[]
  applicants        Applicant[]
  applications      Application[]
  templates         Template[]
  imports           Import[]
  applicantDrafts   ApplicantDraft[]
  auditLogs         AuditLog[]

  @@index([code])
  @@index([email])
  @@map("organizations")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  role              UserRole
  phone             String?
  avatar            String?
  isActive          Boolean   @default(true)
  lastLogin         DateTime? @db.Timestamp(3)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  sessions          Session[]
  blacklistedTokens TokenBlacklist[]
  assignedGroups    Group[]       @relation("GroupEmployee")
  auditLogs         AuditLog[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model Session {
  id                String    @id @default(cuid())
  token             String    @unique
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt         DateTime  @db.Timestamp(3)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

// ==================== VISA PROCESSING ====================

model Group {
  id                String    @id @default(cuid())
  code              String
  name              String
  travelDate        DateTime? @db.Timestamp(3)
  externalAgent     String?
  notes             String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedEmployeeId String?
  assignedEmployee  User?     @relation("GroupEmployee", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)

  applicants        Applicant[]
  imports           Import[]

  @@unique([code, organizationId])
  @@index([organizationId])
  @@index([assignedEmployeeId])
  @@index([isActive])
  @@map("groups")
}

model Applicant {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  email             String?
  phone             String?
  dob               DateTime? @db.Timestamp(3)
  gender            String?
  nationality       String?
  passportNumber    String?
  passportExpiry    DateTime? @db.Timestamp(3)
  passportIssue     DateTime? @db.Timestamp(3)
  address           String?
  city              String?
  country           String?
  photo             String?
  documents         Json?
  notes             String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  groupId           String
  group             Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  applications      Application[]

  @@index([organizationId])
  @@index([groupId])
  @@index([email])
  @@index([passportNumber])
  @@map("applicants")
}

model Application {
  id                String    @id @default(cuid())
  referenceNumber   String    @unique
  visaType          String
  destinationCountry String
  status            ApplicationStatus @default(DRAFT)
  submittedAt       DateTime? @db.Timestamp(3)
  processedAt       DateTime? @db.Timestamp(3)
  approvedAt        DateTime? @db.Timestamp(3)
  rejectedAt        DateTime? @db.Timestamp(3)
  rejectionReason   String?
  notes             String?
  documents         Json?
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  applicantId       String
  applicant         Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  templateId        String?
  template          Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  auditLogs         AuditLog[]

  @@index([organizationId])
  @@index([applicantId])
  @@index([templateId])
  @@index([status])
  @@index([referenceNumber])
  @@map("applications")
}

model Template {
  id                String    @id @default(cuid())
  name              String
  country           String
  visaType          String
  description       String?
  fields            Json
  conditions        Json?
  version           Int       @default(1)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  applications      Application[]

  @@unique([name, country, visaType, organizationId])
  @@index([organizationId])
  @@index([country])
  @@index([visaType])
  @@map("templates")
}

// ==================== IMPORTS & OCR ====================

model Import {
  id                String    @id @default(cuid())
  fileName          String
  fileType          String
  fileSize          Int
  filePath          String
  status            ImportStatus @default(PENDING)
  processedCount    Int       @default(0)
  totalCount        Int       @default(0)
  errorCount        Int       @default(0)
  errors            Json?
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  groupId           String?
  group             Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)

  drafts            ApplicantDraft[]

  @@index([organizationId])
  @@index([groupId])
  @@index([status])
  @@map("imports")
}

model ApplicantDraft {
  id                String    @id @default(cuid())
  importId          String
  import            Import    @relation(fields: [importId], references: [id], onDelete: Cascade)
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  extractedData     Json
  fieldConfidence   Json
  confidence        Int
  status            String    @default("PENDING_REVIEW")
  corrections       Json?
  originalSource    String?
  reviewedBy        String?
  reviewedAt        DateTime? @db.Timestamp(3)
  createdAt         DateTime  @default(now()) @db.Timestamp(3)
  updatedAt         DateTime  @updatedAt @db.Timestamp(3)

  @@index([importId])
  @@index([organizationId])
  @@index([status])
  @@index([confidence])
  @@map("applicant_drafts")
}

// ==================== AUDIT ====================

model AuditLog {
  id                String    @id @default(cuid())
  action            String
  entityType        String
  entityId          String
  oldValues         Json?
  newValues         Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime  @default(now()) @db.Timestamp(3)

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId            String?
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  applicationId     String?
  application       Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([applicationId])
  @@index([entityType])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model TokenBlacklist {
  id                String    @id @default(cuid())
  token             String    @unique
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  blacklistedAt      DateTime  @default(now()) @db.Timestamp(3)
  expiresAt         DateTime  @db.Timestamp(3)
  reason            String?
  createdAt         DateTime  @default(now()) @db.Timestamp(3)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("token_blacklist")
}
